# User identity — auto-detected by home directory
[includeIf "gitdir:/Users/dalab-yolo/"]
	path = ~/dotfiles/.gitconfig.user.dalab-yolo
[includeIf "gitdir:/Users/dalab-tech/"]
	path = ~/dotfiles/.gitconfig.user.dalab-tech
[includeIf "gitdir:/Users/lamson-dev/"]
	path = ~/dotfiles/.gitconfig.user.lamson-dev
[includeIf "gitdir:/Users/dalab-anton/"]
	path = ~/dotfiles/.gitconfig.user.dalab-anton

[pull]
    rebase = true

[branch]
    autosetuprebase = always

[alias]
    rh = reset --hard HEAD
    b = checkout -b
    co = checkout
    ca = commit -a --verbose
    cm = commit -m
    cp = cherry-pick
    amend = commit --amend --no-edit
    unstage = reset HEAD
    cdiff = "!f() { git diff \"$1^\" \"$1\"; }; f"
    rollback = reset --soft HEAD^

[push]
    default = current

[core]
    pager = delta -- --theme="night-owlish"
    excludesfile = ~/.gitignore_global
    ignorecase = false
	editor = vim

[interactive]
    diffFilter = delta --color-only

[color]
    ui = true

[color "diff-highlight"]
    oldNormal = red bold
    oldHighlight = red bold 52
    newNormal = green bold
    newHighlight = green bold 22

[color "diff"]
    meta = 11
    frag = magenta bold
    commit = yellow bold
    old = red bold
    new = green bold
    whitespace = red reverse

[init]
    defaultBranch = main

[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
