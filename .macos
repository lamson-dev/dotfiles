#!/usr/bin/env bash
set -euo pipefail

###############################################################################
# .macos — Bootstrap a fresh Mac
#
# For a new machine (admin):
#   curl -fsSL https://raw.githubusercontent.com/lamson-dev/dotfiles/master/.macos | bash
#
# For a new user on an already-setup machine:
#   cd ~/dotfiles && bash scripts/setup-user.sh
#
# Scripts:
#   scripts/setup-admin.sh  — Xcode, Homebrew, apps, fonts (requires sudo)
#   scripts/setup-user.sh   — dotfiles, shell config, defaults (no sudo)
#   scripts/setup-macos-defaults.sh — macOS preferences (no sudo)
#
# Idempotent — safe to run multiple times.
###############################################################################

DOTFILES="$HOME/dotfiles"
REPO="https://github.com/lamson-dev/dotfiles.git"

echo "Hello $(whoami)! Let's get you set up."
echo ""

###############################################################################
# Clone dotfiles (needed before we can run scripts)
###############################################################################
if [ -d "$DOTFILES" ]; then
  echo "Dotfiles already exist at $DOTFILES, pulling latest..."
  git -C "$DOTFILES" stash --quiet 2>/dev/null || true
  git -C "$DOTFILES" pull --rebase
  git -C "$DOTFILES" stash pop --quiet 2>/dev/null || true
else
  # Ensure git is available (comes with Xcode CLI tools)
  if ! command -v git &>/dev/null; then
    echo "ERROR: git not found. Install Xcode CLI tools first: xcode-select --install"
    exit 1
  fi
  echo "Cloning dotfiles to $DOTFILES..."
  git clone "$REPO" "$DOTFILES"
fi

###############################################################################
# Run the appropriate scripts
###############################################################################
export DOTFILES

if sudo -v 2>/dev/null; then
  echo ""
  echo "==> Running admin setup (machine + current user)..."
  bash "$DOTFILES/scripts/setup-admin.sh"
else
  echo ""
  echo "No sudo access — running user setup only."
  echo "(If apps/Homebrew aren't installed, ask an admin to run: sudo bash scripts/setup-admin.sh $USER)"
  echo ""
  bash "$DOTFILES/scripts/setup-user.sh"
fi
