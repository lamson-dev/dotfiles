# Machine-local secrets and project-specific config
# Copy to ~/.zprofile.local and fill in values
# NEVER commit this file to git

# API keys / tokens
export NPM_TOKEN=
export GOOGLE_GENAI_API_KEY=
export GEMINI_API_KEY=

# GCP project config
export FV__GCP_PROJECT=
export FV__GCP_STORAGEBUCKET=
export FIREBASE_CONFIG=

